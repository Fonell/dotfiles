alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias .....="cd ../../../.."
alias ......="cd ../../../../.."

alias ls='eza --icons --group-directories-first'
alias ll='eza -la --icons --group-directories-first --git --time-style=long-iso'
alias lt='eza -la --icons --group-directories-first --tree --level=2'

alias n='nvim'
alias c='clear'
alias lzg='lazygit'
alias lzd='lazydocker'
